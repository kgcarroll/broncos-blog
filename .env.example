# Sanity (public reads + Studio)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Site URL (Presentation tool iframe + stega)
NEXT_PUBLIC_SITE_URL=http://localhost:3333

# Viewer token: Presentation tool, draft mode, live preview (read-only)
# sanity.io/manage -> API -> Tokens -> Viewer
SANITY_API_READ_TOKEN=

# Editor token: required for npm run seed:schedule (Viewer cannot create documents)
# sanity.io/manage -> API -> Tokens -> Editor
SANITY_API_WRITE_TOKEN=
